# Database (MySQL)
DATABASE_URL="mysql://user:password@localhost:3306/phoenix_user"

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=3600

# Server
PORT=3000
NODE_ENV=development

# Logging (trace | debug | info | warn | error | fatal)
LOG_LEVEL=debug
# Optional: log Prisma SQL queries (set to 1 when debugging DB issues)
# PRISMA_LOG_QUERIES=1

# Build/version (optional; included in server_started log metadata)
# VERSION=1.0.0
# COMMIT_SHA=abc1234
# BUILD_ID=build-42

# Seed: super admin user (optional; used by `prisma db seed`)
# SUPER_ADMIN_EMAIL=admin@phoenix.local
# SUPER_ADMIN_PASSWORD=ChangeMeOnFirstLogin!
# SUPER_ADMIN_NAME=Super Admin
