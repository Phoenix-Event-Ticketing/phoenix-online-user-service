{
  "name": "phoenix-online-user-service",
  "version": "1.0.0",
  "description": "Authentication, authorization, and user identity for Phoenix-Online event booking platform",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "lint": "eslint src/"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [
    "phoenix-online",
    "user-service",
    "auth",
    "rbac"
  ],
  "license": "UNLICENSED",
  "private": true,
  "overrides": {
    "test-exclude": "8.0.0",
    "tar": ">=7.5.11",
    "@hono/node-server": "^1.19.10",
    "hono": ">=4.12.6",
    "effect": ">3.20.0",
    "lodash": ">=4.17.21",
    "@chevrotain/cst-dts-gen": ">10.5.0",
    "@chevortain/gast": ">10.5.0",
    "chevrotain": ">10.5.0",
    "minimatch": ">10.2.3"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.5.0",
    "@prisma/client": "7.5.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "helmet": "^7.1.0",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "mariadb": "^3.5.2",
    "pino": "^9.4.0",
    "pino-http": "^10.2.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prisma": "^7.5.0",
    "supertest": "^7.0.0"
  }
}
